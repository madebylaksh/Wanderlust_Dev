<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-6 offset-3">

            <h1> Creating a new Listing </h1>
            
            <form method="post" action="/listings/new" class="needs-validation" novalidate enctype="multipart/form-data">
                <label class="form-label mb-0">Title</label>
                <div class="mb-3">
                    <input class="form-control" name ="listing[title]" placeholder="Add a catchy title" required>
                    <div class="valid-feedback"> Looks good! </div>
                    <div class="invalid-feedback"> A title is required </div>
                </div>

                <label class="form-label mb-0">Description</label>
                <div class="mb-3">
                    <textarea class="form-control" name ="listing[description]" required></textarea>
                    <div class="valid-feedback"> Looks good! </div>
                    <div class="invalid-feedback"> Describe the place </div>
                </div>
                

                <label class="form-label mb-0">Image</label>
                <!-- <div class="mb-3">
                    <input class="form-control" name ="listing[image][url]" placeholder="enter URL/image link">
                </div> -->
                <div class="mb-3">
                    <input class="form-control"  type="file" name="avatar" required>
                    <div class="valid-feedback"> Looks good! </div>
                    <div class="invalid-feedback"> Upload an image of your listing </div>
                </div>
                

                <div class="row">
                    <div class="col-md-4">                                                                      <!-- small screen = price and country seperate lines -->
                        <label class="form-label mb-0">Price</label>
                        <div class="mb-3">
                            <input class="form-control" name ="listing[price]" placeholder="1200" type="number" required>
                            <div class="valid-feedback"> Looks good! </div>
                            <div class="invalid-feedback"> Enter the listing's price </div>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label mb-0">Country</label>
                        <div class="mb-3">
                            <input class="form-control" name ="listing[location]" placeholder="India" required>
                            <div class="valid-feedback"> Looks good! </div>
                            <div class="invalid-feedback"> Country is required </div>
                        </div>
                    </div>
                </div>

                <label class="form-label mb-0">Location</label>
                <div class="mb-3">
                    <input class="form-control" name ="listing[country]" placeholder="Jaipur, Rajasthan" required>
                    <div class="valid-feedback"> Looks good! </div>
                    <div class="invalid-feedback"> Mention the location of listing</div>
                </div>
                <button class="btn btn-dark add-btn mb-5">Add to the listings </button>
            </form>
            
        </div>

    </div>
</body>