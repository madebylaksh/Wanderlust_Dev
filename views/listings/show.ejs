<% layout("/layouts/boilerplate.ejs") %>
<body>
        <div class="row">
            <div class="col-6 mx-auto">
                <h1 class="mb-4"> <%-listing.title%> </h1>
                <div class="card listing-card mb-3">
                        <img src="<%-listing.image.url%>" class="img-show card-img-top" alt="...">
                        <div class="card-body mt-4 ">
                            <h4 class="  text-muted mb-4"> Owned By: <%- listing.owner.username %> </h4>
                            <p> <%- listing.description %> </p>
                            <p> &#8377;<%- listing.price.toLocaleString("en-IN") %></p>
                            <p> <%- listing.location %> </p>
                            <p> <%- listing.country %> </p>
                        </div>
                </div>
                
                <% if (user && listing.owner._id.equals(user._id)) { %>
                    <form action="/listings/<%-id%>/edit" class="d-inline">
                        <button class="btn btn-dark edit-btn mb-5"> Edit this listing</button>
                    </form>
                    <form method="post" action="/listings/<%-id%>/delete?_method=DELETE" class="d-inline ms-3">
                        <button class="btn btn-dark mb-5 delete-btn"> Delete this listing </button>
                    </form>
                <%  } 
                
                if (user) { %>
                    <hr>
                    <h1>Leave a Review</h1>
                    <form method="post" action="/listings/<%-id%>/review" class="needs-validation" novalidate>

                        <label> Rating: </label>
                        <fieldset class="starability-checkmark">
                            
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                        
                        <label> Comments </label>
                        <div class="mb-3">
                            <textarea placeholder="Your opinion matters" class="mt-1 w-100 p-md-3 form-control" rows="10" name="review[comment]" required></textarea>
                            <div class="valid-feedback">Looks good!</div>
                            <div class="invalid-feedback">Support your rating by writing a comment.</div>
                        </div>
                        <button class="review-btn btn btn-dark mb-5">Submit</button>
                    </form>
                <% } %>

                <hr>
                <h5 class="mb-4"> All Reviews </h5>
                <div class="row">
                    <% for (let review of listing.reviews) { %>
                        <div class="card col-5 mb-3 ms-3">
                            <div class="card-body">
                                <h5 class="card-title"> <%- review.author.username %> </h5>
                                <div class="card-text mb-4 starability-result" data-rating="<%-review.rating%>">
                                </div>
                                <div class="card-text review-card">
                                    <%-review.comment%>
                                </div>
                                <form method="post" action="/listings/<%-id%>/review/<%-review._id%>?_method=DELETE">
                                    <button class="btn btn-warning mt-3 mb-3">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

</body>
