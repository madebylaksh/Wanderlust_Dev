<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-6 offset-3">
            <h1 class="mb-4"> Edit your Listing </h1>
            <form method="post" action="/listings/<%-id%>/edit?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">

                <label class="form-label">Title</label>
                <div class="mb-3">
                    <input class="form-control" name="listing[title]" value="<%-listing.title%>" required>
                    <div class="invalid-feedback">
                        A title is required.
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <label class="form-label">Description</label>
                <div class="mb-3">
                    <textarea class="form-control" rows="5" cols = "50" name="listing[description]" required><%-listing.description%></textarea>
                    <div class="invalid-feedback">
                        Description of your listing is required.
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                    <figure class="figure mt-3 mb-3">
                        <figcaption class="figure-caption">Current Image</figcaption>
                        <img class="figure-img img-fluid rounded" src="<%-originalImageUrl%>">
                    </figure>
                    <div class="mb-3">
                        <label class="form-label">Upload a new Image</label>
                        <input class="form-control" name="new-img" type="file">
                    </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label class="form-label">Price</label>
                        <input class="form-control" name="listing[price]" value="<%-listing.price%>" required>
                        <div class="invalid-feedback">
                            Mention the price.
                        </div>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label class="form-label">Country</label>
                        <input class="form-control" name="listing[country]" value="<%-listing.country%>" required>
                        <div class="invalid-feedback">
                            Enter the country.
                        </div>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                </div>

                <label class="form-label">Location</label>
                <div class="mb-3">
                    <input class="form-control" name="listing[location]" value="<%-listing.location%>" required>
                    <div class="invalid-feedback">
                        Location is required.
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <button class="btn btn-dark edit-btn mb-5 mt-3">Save Changes</button>
            </form>
        </div>
    </div>
</body>