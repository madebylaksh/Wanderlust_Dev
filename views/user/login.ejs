<% layout ("layouts/boilerplate.ejs") %>

<body>
    <div class="row justify-content-center login">
        <div class="col-5">
            <h1 class="mb-5"> Login </h1>
            <form action="/user/login" method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label"> Username </label>
                    <input name="username" class="form-control" placeholder="What should be your username?" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Username can't be empty
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label"> Password </label>
                    <input name="password" class="form-control" placeholder="Enter a password" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Password is required for authentication
                    </div>
                </div>
                <button class="btn btn-dark login-btn mt-3 d-block mx-auto">Login</button>
            </form>
        </div>  
    </div>
</body>